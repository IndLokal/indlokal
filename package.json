{
  "name": "indlokal",
  "version": "0.1.0",
  "private": true,
  "description": "IndLokal monorepo (web + mobile + shared contracts)",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm -F web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md}\" --ignore-path .gitignore",
    "check": "turbo run typecheck lint && pnpm format:check",
    "openapi:generate": "pnpm -F @indlokal/shared openapi:generate",
    "db:generate": "pnpm -F web db:generate",
    "db:push": "pnpm -F web db:push",
    "db:migrate": "pnpm -F web db:migrate",
    "db:migrate:deploy": "pnpm -F web db:migrate:deploy",
    "db:seed": "pnpm -F web db:seed",
    "db:studio": "pnpm -F web db:studio",
    "db:reset": "pnpm -F web db:reset",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.3.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser@<5.7.0": ">=5.7.0",
      "fast-xml-builder@<1.1.7": ">=1.1.7",
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
