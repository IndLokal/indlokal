{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "description": "IndLokal web app (Next.js)",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "build:vercel": "prisma generate && prisma migrate deploy && node scripts/maybe-bootstrap.cjs && node scripts/maybe-directory.cjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:bootstrap": "tsx prisma/bootstrap.ts",
    "db:directory": "tsx prisma/directory.ts",
    "db:resources": "tsx prisma/resources.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:setup": "bash -c 'docker compose exec -T db psql -U postgres -c \"CREATE DATABASE indlokal_test;\" 2>/dev/null || true && DATABASE_URL=${TEST_DATABASE_URL} pnpm exec prisma db push --skip-generate'",
    "pipeline": "tsx src/modules/pipeline/run.ts",
    "pipeline:city": "tsx src/modules/pipeline/run.ts --city"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1034.0",
    "@aws-sdk/s3-request-presigner": "^3.1034.0",
    "@indlokal/shared": "workspace:*",
    "@prisma/client": "^6.6.0",
    "date-fns": "^4.1.0",
    "jose": "^6.2.2",
    "next": "16.2.3",
    "nodemailer": "^8.0.5",
    "posthog-js": "^1.369.2",
    "posthog-node": "^5.29.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.11.0",
    "slugify": "^1.6.6",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^25.0.0",
    "prisma": "^6.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
