# Environment variables for IndLokal
# Copy this file to .env.local and fill in the values required for local development.

# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/indlokal?schema=public"
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5434/indlokal_test?schema=public"

# ─── Next.js ───
PORT=3001
# Production example: https://indlokal.com
# In Vercel production, set this to your canonical HTTPS domain.
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="IndLokal"

# ─── Bootstrap / Admin seed ───
# Admin account created/promoted by bootstrap seed during deploy
ADMIN_EMAIL="admin@indlokal.com"
# Set true in Vercel to run bootstrap in build:vercel
RUN_BOOTSTRAP_SEED="false"

# ─── Email (Resend) ───
# Leave blank in development to log emails to the console instead of sending
RESEND_API_KEY=""
# Override the sender address (must be a verified domain in Resend)
RESEND_FROM_EMAIL="IndLokal <noreply@indlokal.com>"

# ─── Analytics (optional) ───
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# ─── Google OAuth (optional) ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Cron / Internal Jobs ───
CRON_SECRET=""

# ─── Feature Flags (local defaults)
FEATURE_REPORT="true"
# JOURNEY_LAYER_ENABLED=true
# JOURNEY_CITY_PERSONA_ALLOWLIST=stuttgart:young-family
# JOURNEY_TAG_SUGGESTIONS_ENABLED=false

# ─── Optional external APIs (only set if you use them locally)
# OPENAI_API_KEY=""
# EVENTBRITE_API_KEY=""
# GOOGLE_CSE_API_KEY=""
# GOOGLE_CSE_COMMUNITY_ID=""
# GOOGLE_CSE_EVENT_ID=""
# GOOGLE_CSE_RESOURCE_ID=""
# Optional legacy fallback used when lane-specific IDs are not set:
# GOOGLE_CSE_ID=""
# Optional DB-source discovery tuning (defaults shown):
# PIPELINE_DB_SOURCE_PROBE_TIMEOUT_MS=4000
# PIPELINE_DB_SOURCE_PROBE_CONCURRENCY=5
# PIPELINE_DB_SOURCE_DISCOVERY_TOP_K=5

# Notes:
# Keep this file minimal. Add production secrets to your deployment environment
# (Vercel, Docker secrets, or a secrets manager). Only include the vars you
# actually need locally in `.env.local`.
