{
  "expo": {
    "owner": "indlokal",
    "name": "IndLokal",
    "slug": "indlokal-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "indlokal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.indlokal.mobile",
      "associatedDomains": ["applinks:indlokal.com"]
    },
    "android": {
      "package": "com.indlokal.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "indlokal.com",
              "pathPrefix": "/auth"
            },
            {
              "scheme": "https",
              "host": "indlokal.com",
              "pathPattern": "/.*/events/.*"
            },
            {
              "scheme": "https",
              "host": "indlokal.com",
              "pathPattern": "/.*/communities/.*"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "IndLokal needs access to your photos so you can add an image to an event or community you submit.",
          "cameraPermission": "IndLokal needs access to your camera so you can take a photo for an event or community you submit."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "06138335-76d5-4e0b-bb56-a83e6cd3a3a7"
      }
    }
  }
}
