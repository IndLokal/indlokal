# Environment variables for LocalPulse
# Copy this file to .env.local and fill in the values

# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/localpulse?schema=public"

# ─── Next.js ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LocalPulse"

# ─── Analytics (PostHog) ───
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
