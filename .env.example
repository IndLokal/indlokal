# Environment variables for LocalPulse
# Copy this file to .env.local and fill in the values

# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/localpulse?schema=public"
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/localpulse_test?schema=public"

# ─── Next.js ───
PORT=3001
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="LocalPulse"

# ─── Email (Resend) ───
# Get your API key at https://resend.com — free tier: 3,000 emails/month
# Leave blank in development to log emails to the console instead of sending
RESEND_API_KEY=""
# Override the sender address (must be a verified domain in Resend)
RESEND_FROM_EMAIL="LocalPulse <noreply@localpulse.de>"

# ─── Analytics ──────────────────────────────────────────────────────────────
# Plausible (lightweight page views — optional)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# PostHog (product analytics — funnels, identity, session recordings)
# Get your key from https://eu.posthog.com (EU cloud) or your self-hosted instance
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# ─── Google OAuth ───
# Create OAuth credentials at https://console.cloud.google.com > APIs & Services > Credentials
# Authorised redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Cron / Internal Jobs ───
# Shared secret for authenticated /api/cron/* routes
CRON_SECRET=""

# ─── AI Pipeline ───
# Required for LLM-based extraction and enrichment
OPENAI_API_KEY=""
# Optional override; default in code is gpt-4o-mini
# PIPELINE_LLM_MODEL="gpt-4o-mini"

# Optional external source APIs
# EVENTBRITE_API_KEY=""
# GOOGLE_CSE_API_KEY=""
# GOOGLE_CSE_ID=""
